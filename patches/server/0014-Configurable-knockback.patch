From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: hpfxd <me@hpfxd.com>
Date: Sat, 30 Oct 2021 14:26:06 -0400
Subject: [PATCH] Configurable knockback

This patch allows velocity applied when a player is hit to be modified in the configuration.

Reference: https://gist.github.com/YoungOG/e3265d98661957abece71594b70d6a01

diff --git a/src/main/java/com/hpfxd/pandaspigot/config/PandaSpigotWorldConfig.java b/src/main/java/com/hpfxd/pandaspigot/config/PandaSpigotWorldConfig.java
index 9afaf630481a9533fb014f306d4d90b8de80a129..77f3c6b8f9de4f5f4d756916609d9d3d1b3b5d7f 100644
--- a/src/main/java/com/hpfxd/pandaspigot/config/PandaSpigotWorldConfig.java
+++ b/src/main/java/com/hpfxd/pandaspigot/config/PandaSpigotWorldConfig.java
@@ -6,4 +6,65 @@ import org.spongepowered.configurate.objectmapping.meta.Comment;
 @ConfigSerializable
 @SuppressWarnings({"FieldCanBeLocal", "FieldMayBeFinal"})
 public class PandaSpigotWorldConfig {
+    @Comment("These options control velocity players receive when damaged.")
+    public KnockbackConfig knockback;
+
+    @ConfigSerializable
+    public static class KnockbackConfig {
+        @Comment("Preset used for knockback. Available: custom, default, blockhit, slowdown, vertical")
+        public String preset = "custom";
+
+        public double friction = 2.0;
+        public double horizontal = 0.4;
+        public double vertical = 0.4;
+        public double verticalLimit = 0.4000000059604645;
+        public double extraHorizontal = 0.5;
+        public double extraVertical = 0.1;
+        public boolean stopSprinting = true;
+        public double sprintingSlowdown = 0.6;
+        public int hitDelay = 20;
+
+        public Profile getProfile() {
+            switch (this.preset.toLowerCase(java.util.Locale.ROOT)) {
+                case "blockhit":
+                    return new Profile(9.0, 0.56, 0.34, 0.6, 0.24, 0.04, true, 0.65, 20);
+                case "default":
+                    return new Profile(9.0, 0.56, 0.35, 1.0, 0.18, 0.03, true, 0.65, 19);
+                case "slowdown":
+                    return new Profile(9.2, 0.56, 0.34, 0.6, 0.17, 0.045, true, 1.0, 20);
+                case "vertical":
+                    return new Profile(6.0, 0.58, 0.34, 0.6, 0.25, 0.045, true, 1.0, 20);
+                default:
+                    return new Profile(this.friction, this.horizontal, this.vertical, this.verticalLimit,
+                            this.extraHorizontal, this.extraVertical, this.stopSprinting, this.sprintingSlowdown,
+                            this.hitDelay);
+            }
+        }
+
+        public static final class Profile {
+            public final double friction;
+            public final double horizontal;
+            public final double vertical;
+            public final double verticalLimit;
+            public final double extraHorizontal;
+            public final double extraVertical;
+            public final boolean stopSprinting;
+            public final double sprintingSlowdown;
+            public final int hitDelay;
+
+            private Profile(double friction, double horizontal, double vertical, double verticalLimit,
+                            double extraHorizontal, double extraVertical, boolean stopSprinting,
+                            double sprintingSlowdown, int hitDelay) {
+                this.friction = friction;
+                this.horizontal = horizontal;
+                this.vertical = vertical;
+                this.verticalLimit = verticalLimit;
+                this.extraHorizontal = extraHorizontal;
+                this.extraVertical = extraVertical;
+                this.stopSprinting = stopSprinting;
+                this.sprintingSlowdown = sprintingSlowdown;
+                this.hitDelay = hitDelay;
+            }
+        }
+    }
 }
